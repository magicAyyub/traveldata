# Copy to .env and fill in. All vars are optional except where noted.
TRAVELDATA_DATABASE_URL=postgresql+psycopg://traveldata:traveldata@localhost:5432/traveldata
TRAVELDATA_OPENTRIPMAP_API_KEY=
TRAVELDATA_DEFAULT_LANG=en
TRAVELDATA_HTTP_MIN_INTERVAL_S=1.0
TRAVELDATA_USER_AGENT=traveldata/0.1 (+https://example.com; data@example.com)
